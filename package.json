{
  "name": "worksidesupportconsole",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --open --port 3000",
    "start": "vite --open --port 3000",
    "build": "vite build",
    "test": "vitest run tests/chat.normalize.test.js tests/filterSummary.test.js tests/sessionListRender.test.js tests/dialogRender.test.js tests/routingNotificationsRender.test.js tests/inactivityState.test.js --pool=threads",
    "test:e2e": "playwright test",
    "test:e2e:live:support": "playwright test --config=playwright.live.config.js",
    "test:e2e:live:public": "playwright test --config=playwright.public.config.js",
    "test:e2e:live:qa": "playwright test --config=playwright.qa.config.js",
    "mobile:start": "npm --prefix mobile-support-app run start",
    "mobile:typecheck": "npm --prefix mobile-support-app run typecheck",
    "audit:prod": "npm audit --omit=dev",
    "mobile:audit:prod": "npm --prefix mobile-support-app audit --omit=dev",
    "load:public-chat": "node scripts/run-k6.js load-tests/public-chat-load.js",
    "load:support-api": "node scripts/run-k6.js load-tests/support-api-load.js",
    "load:support-multi-user": "node scripts/run-k6.js load-tests/support-multi-user.js",
    "cleanup:chat-sessions": "node scripts/purge-chat-sessions-before.js",
    "preview": "vite preview",
    "verify:release": "node ./scripts/verify-release.js",
    "verify:release:local": "node ./scripts/verify-release.js --target local",
    "verify:release:prod": "node ./scripts/verify-release.js --target production",
    "test:puppeteer": "node ./scripts/verify-release.js --only routes",
    "test:meta": "node ./scripts/verify-release.js --only meta"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "puppeteer": "^25.2.1",
    "vite": "^8.0.10",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "firebase": "^12.12.1",
    "firebase-admin": "^14.1.0"
  }
}
